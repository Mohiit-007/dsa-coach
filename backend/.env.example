PORT=5000

# MongoDB connection (local or Atlas)
MONGO_URI=mongodb://localhost:27017/dsa-coach

# JWT auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=7d

# Groq AI
GROQ_API_KEY=sk-your-groq-key-here

# Frontend origin(s) for CORS — comma-separated for multiple (e.g. Vercel + localhost)
CLIENT_URL=http://localhost:5173,https://your-app.vercel.app

# Free plan limits
FREE_DAILY_LIMIT=10

# Set to "production" when deploying
NODE_ENV=development

